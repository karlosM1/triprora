VITE_API_URL=/api

# Dev proxy target (vite only, not exposed to the browser).
# Default: http://localhost:3001. The backend must be running for /api requests to work.
# VITE_API_PROXY_TARGET=http://localhost:3001

# Enable when serving through an HTTPS tunnel (localtunnel, ngrok, etc.) so HMR uses wss:443.
# VITE_HMR_TUNNEL=1

# Supabase → Project Settings → API
VITE_SUPABASE_URL=https://yajpbhxytsbyytkhgggp.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
