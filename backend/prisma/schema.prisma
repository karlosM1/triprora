generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum SeatStatus {
  available
  occupied
  selected
}

enum BookingStatus {
  confirmed
  completed
  cancelled
}

enum Role {
  passenger
  driver
  admin
}

enum DriverApplicationStatus {
  pending
  approved
  rejected
}

enum VanStatus {
  draft
  published
  completed
  cancelled
}

enum DriverDocumentType {
  profile_photo
  license_front
  license_back
}

enum VehicleDocumentType {
  cr
  or
  insurance
  inspection
}

enum WalletLedgerType {
  cash_commission
  cashless_earnings
  payout
  settlement_adjustment
  manual_adjustment
}

enum WalletSettlementStatus {
  open
  finalized
}

enum DriverPayoutStatus {
  requested
  approved
  paid
  rejected
}

enum DriverPayoutMethod {
  manual
  paymongo
}

enum PackageType {
  documents
  food
  clothes
  electronics
  others
}

enum PackageWeightBand {
  up_to_1kg
  one_to_5kg
  five_to_10kg
}

enum PackageSize {
  small
  medium
  large
}

enum DeliveryStatus {
  pending
  accepted
  confirmed
  picked_up
  delivered
  declined
  cancelled
}

model Operator {
  id   String @id @default(cuid())
  name String @unique
  vans Van[]

  @@map("operators")
}

model Route {
  id                String  @id @default(cuid())
  departureLocation String
  arrivalLocation   String
  typicalDuration   String?
  vans              Van[]

  @@unique([departureLocation, arrivalLocation])
  @@map("routes")
}

model VanClass {
  id           String @id @default(cuid())
  classType    String
  classVariant String
  baseCapacity Int?
  vans         Van[]

  @@unique([classType, classVariant])
  @@map("van_classes")
}

model Vehicle {
  id             String            @id @default(cuid())
  ownerProfileId String            @db.Uuid
  owner          Profile           @relation(fields: [ownerProfileId], references: [id], onDelete: Cascade)
  plateNumber    String
  make           String
  model          String
  year           Int
  color          String
  capacity       Int
  photoUrl       String?
  documents      VehicleDocument[]
  vans           Van[]
  application    DriverApplication?

  @@map("vehicles")
}

model VehicleDocument {
  id        String              @id @default(cuid())
  vehicleId String
  vehicle   Vehicle             @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  type      VehicleDocumentType
  url       String
  expiresAt DateTime?

  @@unique([vehicleId, type])
  @@map("vehicle_documents")
}

model Van {
  id            String       @id
  routeId       String
  route         Route        @relation(fields: [routeId], references: [id])
  operatorId    String
  operator      Operator     @relation(fields: [operatorId], references: [id])
  vanClassId    String
  vanClass      VanClass     @relation(fields: [vanClassId], references: [id])
  vehicleId     String?
  vehicle       Vehicle?     @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  departureTime String
  arrivalTime   String
  duration      String
  price         Int
  seatsLeft     Int
  totalSeats    Int?
  departureDate String       @default("")
  tripCategory  String?
  status        VanStatus    @default(published)
  driverId      String?      @db.Uuid
  driver        Profile?     @relation(fields: [driverId], references: [id], onDelete: Cascade)
  seats         Seat[]
  bookings      Booking[]
  deliveries    Delivery[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([status, departureDate])
  @@index([driverId])
  @@index([routeId])
}

model Seat {
  id       String     @id @default(cuid())
  vanId    String
  van      Van        @relation(fields: [vanId], references: [id], onDelete: Cascade)
  label    String
  status   SeatStatus @default(available)
  premium  Boolean    @default(false)
  bookings Booking[]

  @@unique([vanId, label])
}

model Profile {
  id        String   @id @db.Uuid
  email     String   @unique
  fullName  String?
  phone     String?
  dateOfBirth String?
  gender    String?
  nationality String?
  houseStreet String?
  barangay  String?
  city      String?
  province  String?
  zipCode   String?
  emergencyContactName         String?
  emergencyContactRelationship String?
  emergencyContactPhone        String?
  role      Role     @default(passenger)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  driverApplication DriverApplication?
  bookings          Booking[]
  deliveries        Delivery[]
  vans              Van[]
  vehicles          Vehicle[]
  payments          Payment[]
  driverWallet      DriverWallet?
  driverPayouts     DriverPayout[]
  walletSettlements WalletDailySettlement[]
  walletAuditLogs   WalletAuditLog[]        @relation("WalletAuditActor")
  destinationAddresses DestinationAddress[]

  @@map("profiles")
}

model DestinationAddress {
  id          String   @id @default(cuid())
  profileId   String   @db.Uuid
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  label       String
  houseStreet String
  barangay    String?
  city        String
  province    String
  zipCode     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([profileId])
  @@map("destination_addresses")
}

model Address {
  id          String              @id @default(cuid())
  houseStreet String
  barangay    String
  city        String
  province    String
  zipCode     String
  application DriverApplication?

  @@map("addresses")
}

model EmergencyContact {
  id           String              @id @default(cuid())
  name         String
  relationship String
  phone        String
  application  DriverApplication?

  @@map("emergency_contacts")
}

model DriverBankAccount {
  id            String              @id @default(cuid())
  gcashNumber   String?
  accountName   String?
  bankName      String?
  accountNumber String?
  application   DriverApplication?

  @@map("driver_bank_accounts")
}

model DriverDocument {
  id            String             @id @default(cuid())
  applicationId String
  application   DriverApplication  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  type          DriverDocumentType
  url           String

  @@unique([applicationId, type])
  @@map("driver_documents")
}

model DriverApplication {
  id        String @id @default(cuid())
  profileId String @unique @db.Uuid
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  firstName   String
  middleName  String?
  lastName    String
  suffix      String?
  dateOfBirth String
  gender      String
  nationality String

  licenseNo         String
  licenseType       String
  licenseExpiration String

  addressId String  @unique
  address   Address @relation(fields: [addressId], references: [id], onDelete: Cascade)

  emergencyContactId String           @unique
  emergencyContact   EmergencyContact @relation(fields: [emergencyContactId], references: [id], onDelete: Cascade)

  bankAccountId String?            @unique
  bankAccount   DriverBankAccount? @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)

  vehicleId String?  @unique
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  documents DriverDocument[]

  certifyInfo  Boolean @default(false)
  agreeTerms   Boolean @default(false)
  agreePrivacy Boolean @default(false)

  status     DriverApplicationStatus @default(pending)
  reviewedBy String?                 @db.Uuid
  reviewedAt DateTime?
  adminNotes String?
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt

  @@map("driver_applications")
}

model Booking {
  id             String        @id
  userId         String?       @db.Uuid
  user           Profile?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  vanId          String?
  van            Van?          @relation(fields: [vanId], references: [id], onDelete: SetNull)
  seatId         String?
  seat           Seat?         @relation(fields: [seatId], references: [id], onDelete: SetNull)
  reference      String?       @unique
  pickupAddress  String?
  dropoffAddress String?
  status         BookingStatus
  snapshot       BookingSnapshot?
  payment        Payment?
  walletLedgerEntries WalletLedgerEntry[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([userId, status])
  @@index([vanId])
}

model BookingSnapshot {
  bookingId       String  @id
  booking         Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  routeCode       String?
  routeLabel      String
  imageUrl        String?
  departureDate   String
  departureTime   String?
  seatLabel       String
  vehicleLabel    String?
  tripType        String?
  baseFareCents   Int
  serviceFeeCents Int
  taxCents        Int
  totalCents      Int
  currency        String  @default("PHP")
  priceDisplay    String

  @@map("booking_snapshots")
}

model Delivery {
  id                  String            @id
  userId              String?           @db.Uuid
  user                Profile?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  vanId               String?
  van                 Van?              @relation(fields: [vanId], references: [id], onDelete: SetNull)
  reference           String?           @unique
  pickupAddress       String
  dropoffAddress      String
  packageType         PackageType
  weightBand          PackageWeightBand
  size                PackageSize
  description         String
  receiverName        String
  receiverPhone       String
  specialInstructions String?
  photoUrl            String?
  status              DeliveryStatus
  snapshot            DeliverySnapshot?
  payment             Payment?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([userId, status])
  @@index([vanId])
  @@map("deliveries")
}

model DeliverySnapshot {
  deliveryId      String   @id
  delivery        Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  routeCode       String?
  routeLabel      String
  imageUrl        String?
  departureDate   String
  departureTime   String?
  packageLabel    String
  vehicleLabel    String?
  tripType        String?
  baseFareCents   Int
  serviceFeeCents Int
  taxCents        Int
  totalCents      Int
  currency        String   @default("PHP")
  priceDisplay    String

  @@map("delivery_snapshots")
}

model Payment {
  id               String    @id @default(cuid())
  bookingId        String?   @unique
  booking          Booking?  @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  deliveryId       String?   @unique
  delivery         Delivery? @relation(fields: [deliveryId], references: [id], onDelete: SetNull)
  userId           String?   @db.Uuid
  user             Profile?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  provider         String
  providerIntentId String    @unique
  providerMethodId String?
  amount           Int // pesos (not centavos)
  currency         String    @default("PHP")
  status           String
  rawPayload       Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("payments")
}

model DriverWallet {
  id           String   @id @default(cuid())
  driverId     String   @unique @db.Uuid
  driver       Profile  @relation(fields: [driverId], references: [id], onDelete: Cascade)
  balancePesos Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ledgerEntries WalletLedgerEntry[]
  auditLogs     WalletAuditLog[]

  @@map("driver_wallets")
}

model WalletLedgerEntry {
  id                String          @id @default(cuid())
  walletId          String
  wallet            DriverWallet    @relation(fields: [walletId], references: [id], onDelete: Cascade)
  bookingId         String?
  booking           Booking?        @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  payoutId          String?
  payout            DriverPayout?   @relation(fields: [payoutId], references: [id], onDelete: SetNull)
  settlementId      String?
  settlement        WalletDailySettlement? @relation(fields: [settlementId], references: [id], onDelete: SetNull)
  type              WalletLedgerType
  amountPesos       Int
  balanceAfterPesos Int
  baseFarePesos     Int?
  commissionPesos   Int?
  earningsPesos     Int?
  reason            String
  idempotencyKey    String          @unique
  createdAt         DateTime        @default(now())

  @@unique([bookingId])
  @@index([walletId, createdAt])
  @@map("wallet_ledger_entries")
}

model WalletDailySettlement {
  id                     String                 @id @default(cuid())
  driverId               String                 @db.Uuid
  driver                 Profile                @relation(fields: [driverId], references: [id], onDelete: Cascade)
  settlementDate         DateTime               @db.Date
  cashCommissionTotal    Int                    @default(0)
  cashlessEarningsTotal  Int                    @default(0)
  netChange              Int                    @default(0)
  openingBalance         Int
  closingBalance         Int
  bookingCount           Int                    @default(0)
  status                 WalletSettlementStatus @default(open)
  finalizedAt            DateTime?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt

  ledgerEntries WalletLedgerEntry[]

  @@unique([driverId, settlementDate])
  @@index([settlementDate])
  @@map("wallet_daily_settlements")
}

model DriverPayout {
  id              String             @id @default(cuid())
  driverId        String             @db.Uuid
  driver          Profile            @relation(fields: [driverId], references: [id], onDelete: Cascade)
  amountPesos     Int
  status          DriverPayoutStatus @default(requested)
  method          DriverPayoutMethod @default(manual)
  gcashNumber     String?
  accountName     String?
  bankName        String?
  accountNumber   String?
  adminNotes      String?
  reviewedBy      String?            @db.Uuid
  reviewedAt      DateTime?
  paidAt          DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  ledgerEntries WalletLedgerEntry[]

  @@index([driverId, createdAt])
  @@index([status])
  @@map("driver_payouts")
}

model WalletAuditLog {
  id             String       @id @default(cuid())
  walletId       String?
  wallet         DriverWallet? @relation(fields: [walletId], references: [id], onDelete: SetNull)
  actorProfileId String?      @db.Uuid
  actor          Profile?     @relation("WalletAuditActor", fields: [actorProfileId], references: [id], onDelete: SetNull)
  action         String
  entityType     String
  entityId       String?
  before         Json?
  after          Json?
  metadata       Json?
  createdAt      DateTime     @default(now())

  @@index([walletId, createdAt])
  @@index([entityType, entityId])
  @@map("wallet_audit_logs")
}
