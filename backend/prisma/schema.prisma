generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum SeatStatus {
  available
  occupied
  selected
}

enum BookingStatus {
  confirmed
  completed
  cancelled
}

enum Role {
  passenger
  driver
  admin
}

enum DriverApplicationStatus {
  pending
  approved
  rejected
}

enum VanStatus {
  draft
  published
  completed
  cancelled
}

model Van {
  id                String    @id
  classType         String
  classVariant      String
  departureTime     String
  departureLocation String
  arrivalTime       String
  arrivalLocation   String
  duration          String
  operator          String
  amenityKeys       String[]
  price             Int
  seatsLeft         Int
  totalSeats        Int?
  departureDate     String    @default("")
  tripCategory      String?
  vehicleName       String?
  plateNumber       String?
  status            VanStatus @default(published)
  driverId          String?   @db.Uuid
  driver            Profile?  @relation(fields: [driverId], references: [id], onDelete: SetNull)
  seats             Seat[]
  bookings          Booking[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Seat {
  id      String     @id @default(cuid())
  vanId   String
  van     Van        @relation(fields: [vanId], references: [id], onDelete: Cascade)
  label   String
  status  SeatStatus @default(available)
  premium Boolean    @default(false)

  @@unique([vanId, label])
}

model Profile {
  id        String   @id @db.Uuid
  email     String   @unique
  fullName  String?
  phone     String?
  role      Role     @default(passenger)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  driverApplication DriverApplication?
  bookings          Booking[]
  vans              Van[]

  @@map("profiles")
}

model DriverApplication {
  id          String                  @id @default(cuid())
  profileId   String                  @unique @db.Uuid
  profile     Profile                 @relation(fields: [profileId], references: [id], onDelete: Cascade)
  licenseNo   String
  vehicleInfo String?
  status      DriverApplicationStatus @default(pending)
  reviewedBy  String?                 @db.Uuid
  reviewedAt  DateTime?
  adminNotes  String?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@map("driver_applications")
}

model Booking {
  id        String        @id
  userId    String?       @db.Uuid
  user      Profile?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  vanId     String?
  van       Van?          @relation(fields: [vanId], references: [id], onDelete: SetNull)
  reference String?       @unique
  routeCode String?
  image     String?
  date      String
  time      String?
  seat           String?
  pickupAddress  String?
  dropoffAddress String?
  route          String
  vehicle   String?
  tripType  String?
  status    BookingStatus
  price     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}
