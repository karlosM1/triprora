PORT=3001

# Set to "production" in real deployments. Controls logging, CORS strictness,
# and reverse-proxy trust for rate limiting.
NODE_ENV=development

# --- Security / hardening ---------------------------------------------------
# Comma-separated browser origins allowed to call the API (CORS allowlist).
# REQUIRED in production; if empty in production all cross-origin browser calls
# are blocked. In development, localhost origins are allowed automatically.
# e.g. CORS_ORIGINS=https://app.crabr.com,https://admin.crabr.com
CORS_ORIGINS=

# Requests per 15 min window per IP across the whole API (default 600).
RATE_LIMIT_MAX=600
# Requests per 15 min window for privileged writes (role/ban/password/payouts).
SENSITIVE_RATE_LIMIT_MAX=30

# How long (ms) a verified token+profile is cached in memory to avoid a Supabase
# Auth round-trip and DB lookups on every request. Set 0 to disable. Default 30s.
AUTH_CACHE_TTL_MS=30000

# Log verbosity: debug | info | warn | error. Defaults to info in production.
LOG_LEVEL=debug

# Supabase Auth (JWT verification). Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Project Settings → API → service_role (server-only; never expose to frontend)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# First superadmin: profile gets superadmin role when this email signs up
SUPERADMIN_EMAIL=superadmin@example.com
# First admin: profile gets admin role when this email signs up
ADMIN_EMAIL=admin@example.com

# Supabase → Project Settings → Database → Connection string
# If db:push fails with P1000, reset the database password in the dashboard and paste fresh URIs here.
# URL-encode special characters in the password (e.g. @ → %40, ! → %21)
#
# Transaction-mode pooler (app runtime, port 6543)
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
#
# Direct connection (migrations & db push. Use "Direct connection" URI from Supabase, NOT the pooler)
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Local Docker Postgres (docker compose up postgres)
# npm run db:push:local
# DATABASE_URL="postgresql://triprora:triprora@localhost:5433/triprora?schema=public"
# DIRECT_URL="postgresql://triprora:triprora@localhost:5433/triprora?schema=public"
