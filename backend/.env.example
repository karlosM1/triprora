PORT=3001

# Supabase — replace [YOUR-PASSWORD] with your database password
# URL-encode special characters in the password (e.g. @ → %40, ! → %21)
# Transaction-mode pooler (app runtime)
DATABASE_URL="postgresql://postgres.yajpbhxytsbyytkhgggp:[YOUR-PASSWORD]@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Session-mode pooler (migrations & seed)
DIRECT_URL="postgresql://postgres.yajpbhxytsbyytkhgggp:[YOUR-PASSWORD]@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres"

# Local Docker Postgres (optional — npm run db:up; port 5433 avoids conflicts with a local Postgres on 5432)
# DATABASE_URL="postgresql://triprora:triprora@localhost:5433/triprora?schema=public"
# DIRECT_URL="postgresql://triprora:triprora@localhost:5433/triprora?schema=public"
